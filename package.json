{
  "name": "sober",
  "version": "3.0.0",
  "private": true,
  "description": "Sobriety tracker",
  "keywords": [
    "sober",
    "sobriety",
    "time",
    "tracker"
  ],
  "homepage": "https://github.com/chump29/sober",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/sober.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "type": "module",
  "scripts": {
    "build": "bunx --bun vite build",
    "clean": "rimraf bun.lock dist coverage",
    "dev": "bunx --bun vite",
    "preinstall": "bunx --bun only-allow bun",
    "lint": "bun run scan && bun run lint:spell && bun run lint:biome && bun run lint:css && bun run lint:env && bun run lint:html",
    "lint:biome": "biome check --write --verbose",
    "lint:biome:ci": "biome ci --verbose --reporter=default --reporter=github",
    "lint:ci": "bun run lint:spell:ci && bun run lint:biome:ci && bun run lint:css:ci && bun run lint:env && bun run lint:html",
    "lint:css": "stylelint **/*.css --fix --formatter verbose --ignore-path ../.gitignore",
    "lint:css:ci": "stylelint **/*.css --formatter verbose --ignore-path ../.gitignore",
    "lint:env": "dotenv-linter check .",
    "lint:html": "html-validate *.html",
    "lint:spell": "cspell --dot --verbose .",
    "lint:spell:ci": "cspell --dot --verbose --config ./node_modules/@postfmly/config/.vscode/cspell.json .",
    "prepare": "cd .. && husky frontend/.husky",
    "prod": "bun run build && cd dist && bunx serve",
    "scan": "bunx cve-lite-cli",
    "test": "bun test --coverage --isolate --coverage-reporter=text --coverage-reporter=lcov --preload ./src/dom-setup.ts --preload ./src/setup.ts --bail"
  },
  "lint-staged": {
    "*": "cspell --no-must-find-files",
    "*.{json,ts,tsx}": "biome ci --no-errors-on-unmatched",
    "*.css": [
      "biome ci --no-errors-on-unmatched",
      "stylelint"
    ],
    ".env*": "dotenv-linter check",
    "*.html": "html-validate"
  },
  "overrides": {
    "@biomejs/biome": "^2.4.16",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0"
  },
  "dependencies": {
    "@jarrodek/pluralize": "^1.0.2",
    "@mantine/core": "^9.3.1",
    "@mantine/dates": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "@mantine/modals": "^9.3.1",
    "@postfmly/logger": "^1.0.20",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "semver": "^7.8.3",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.2",
    "@postfmly/config": "^1.4.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.2",
    "cspell": "^10.0.1",
    "fdir-size": "^1.0.3",
    "html-validate": "^11.5.3",
    "husky": "^9.1.7",
    "lcov-total": "^2.1.1",
    "lint-staged": "^17.0.7",
    "pretty-bytes": "^7.1.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-jsx-remove-attributes": "^3.1.2",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vite-plugin-minify": "^3.0.0",
    "vite-plugin-package-version": "^1.1.0",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "~1.3.14"
  },
  "engineStrict": true,
  "patchedDependencies": {
    "@jarrodek/pluralize@1.0.2": "patches/@jarrodek%2Fpluralize@1.0.2.patch"
  }
}
