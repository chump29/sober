{
  "name": "sober",
  "version": "3.0.0",
  "private": true,
  "description": "Sobriety tracker",
  "keywords": [
    "sober",
    "sobriety",
    "time",
    "tracker"
  ],
  "homepage": "https://github.com/chump29/sober",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/sober.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "type": "module",
  "scripts": {
    "build": "bun run --bun vite build",
    "clean": "bun run --bun rimraf bun.lock dist coverage",
    "dev": "bun run --bun vite",
    "preinstall": "bunx --bun only-allow bun",
    "lint": "bun run scan && bun run lint:spell && bun run lint:biome && bun run lint:css && bun run lint:env && bun run lint:html && bun run lint:ts",
    "lint:biome": "bun run --bun biome check --write --verbose --error-on-warnings",
    "lint:biome:ci": "bun run --bun biome ci --verbose --reporter=default --reporter=github --error-on-warnings",
    "lint:ci": "bun run scan && bun run lint:biome:ci && bun run lint:css:ci && bun run lint:env && bun run lint:html && bun run lint:ts",
    "lint:css": "bun run --bun stylelint **/*.css --fix --formatter verbose --ignore-path .gitignore",
    "lint:css:ci": "bun run --bun stylelint **/*.css --formatter verbose --ignore-path .gitignore",
    "lint:env": "bun run --bun dotenv-linter check .",
    "lint:html": "bun run --bun html-validate *.html",
    "lint:spell": "bun run --bun cspell --dot --verbose .",
    "lint:ts": "bun run --bun tsgo",
    "prepare": "bun run --bun husky",
    "prod": "bun run build && cd dist && bunx --bun serve",
    "scan": "bunx --bun cve-lite-cli",
    "test": "bun test --coverage --isolate --coverage-reporter=text --coverage-reporter=lcov --preload ./test/dom-setup.ts --preload ./test/setup.ts --bail"
  },
  "lint-staged": {
    "*": "bun run --bun cspell --no-must-find-files",
    "*.{json,ts,tsx}": "bun run --bun biome ci --no-errors-on-unmatched",
    "*.css": [
      "bun run --bun biome ci --no-errors-on-unmatched",
      "bun run --bun stylelint"
    ],
    ".env*": "bun run --bun dotenv-linter check",
    "*.html": "bun run --bun html-validate *.html"
  },
  "overrides": {
    "@biomejs/biome": "^2.5.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0"
  },
  "dependencies": {
    "@jarrodek/pluralize": "^1.0.2",
    "@mantine/core": "^9.3.1",
    "@mantine/dates": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "@mantine/modals": "^9.3.1",
    "@postfmly/logger": "^1.0.20",
    "@tabler/icons-react": "^3.44.0",
    "big.js": "^7.0.1",
    "dayjs": "^1.11.21",
    "ms": "^2.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "semver": "^7.8.4",
    "valibot": "^1.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@happy-dom/global-registrator": "^20.10.3",
    "@postfmly/config": "^1.4.10",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/big.js": "^7.0.0",
    "@types/ms": "^2.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "^7.0.0-dev.20260613.1",
    "@vitejs/plugin-react": "^6.0.2",
    "cspell": "^10.0.1",
    "fdir-size": "^1.0.3",
    "html-validate": "^11.5.3",
    "husky": "^9.1.7",
    "lcov-total": "^2.1.1",
    "lint-staged": "^17.0.7",
    "lit-html": "^3.3.3",
    "pretty-bytes": "^7.1.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-jsx-remove-attributes": "^3.1.2",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "vite-plugin-minify": "^3.0.0",
    "vite-plugin-package-version": "^1.1.0",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "~1.3.14"
  },
  "engineStrict": true,
  "patchedDependencies": {
    "@jarrodek/pluralize@1.0.2": "patches/@jarrodek%2Fpluralize@1.0.2.patch"
  }
}
