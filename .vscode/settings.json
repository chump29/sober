{
  "css.lint.unknownAtRules": "ignore",
  "editor.detectIndentation": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "[css][dockercompose][javacript][javascriptreact][json][typescript][typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[github-actions-workflow][yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "darkriszty.markdown-table-prettify"
  },
  "[nginx]": {
    "editor.defaultFormatter": "ahmadalli.vscode-nginx-conf"
  },
  "[sh]": {
    "editor.defaultFormatter": "timonwong.shellcheck"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.formatDocument": "explicit"
  },
  "markdownlint.config": {
    "MD013": {
      "line_length": 120
    },
    "MD026": {
      "punctuation": ".,;!"
    },
    "MD033": {
      "allowed_elements": ["img"]
    }
  }
}
