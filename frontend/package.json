{
  "name": "sober-frontend",
  "version": "3.0.0",
  "private": true,
  "description": "Sobriety counter (Frontend)",
  "keywords": [
    "sober",
    "sobriety",
    "time",
    "tracker",
    "counter"
  ],
  "homepage": "https://github.com/chump29/sober",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chump29/sober.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Chris Post",
    "email": "admin@postfmly.com"
  },
  "type": "module",
  "scripts": {
    "build": "bun run --bun vite build",
    "check": "bun run check:deps && bun run check:outdated",
    "check:deps": "bunx --bun depcheck --ignores=\"@types/*,bun:*,html-validate,lcov-total,rimraf,stylelint-config-standard,tailwindcss\" || :",
    "check:outdated": "bunx --bun npm-check-updates --install never --dep dev,prod,overrides",
    "clean": "bun run --bun rimraf bun.lock dist tests/coverage",
    "dev": "bun run --bun vite",
    "preinstall": "bunx --bun only-allow bun",
    "lint": "bun run scan && bun run lint:spell && bun run lint:biome && bun run lint:css && bun run lint:env && bun run lint:html && bun run lint:ts",
    "lint:biome": "bun run --bun biome check --write --verbose --error-on-warnings",
    "lint:biome:ci": "bun run --bun biome ci --verbose --reporter=default --reporter=github --error-on-warnings",
    "lint:ci": "bun run scan && bun run lint:biome:ci && bun run lint:css:ci && bun run lint:env && bun run lint:html && bun run lint:ts",
    "lint:css": "bun run --bun stylelint **/*.css --fix --formatter verbose --ignore-path .gitignore",
    "lint:css:ci": "bun run --bun stylelint **/*.css --formatter verbose --ignore-path .gitignore",
    "lint:env": "bun run --bun dotenv-linter check .",
    "lint:html": "bun run --bun html-validate *.html",
    "lint:spell": "bun run --bun cspell --dot --verbose .",
    "lint:ts": "bun run --bun tsc",
    "prepare": "cd .. && bun run --bun husky frontend/.husky",
    "prod": "bun run build && cd dist && bunx --bun serve",
    "scan": "bun run --bun cve-lite --check-overrides",
    "test": "bun test --isolate --coverage --coverage-dir ./tests/coverage --coverage-reporter=text --coverage-reporter=lcov --preload ./tests/dom-setup.ts --preload ./tests/setup.ts --bail"
  },
  "lint-staged": {
    "*": "bun run --bun cspell --no-must-find-files",
    "*.{json,ts,tsx}": "bun run --bun biome ci --no-errors-on-unmatched --error-on-warnings",
    "*.css": [
      "bun run --bun biome ci --no-errors-on-unmatched --error-on-warnings",
      "bun run --bun stylelint"
    ],
    ".env*": "bun run --bun dotenv-linter check",
    "*.html": "bun run --bun html-validate *.html"
  },
  "overrides": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "cspell": "10.0.1",
    "cve-lite-cli": "1.26.0",
    "globals": "17.7.0",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "@jarrodek/pluralize": "^1.0.2",
    "@mantine/core": "^9.4.1",
    "@mantine/dates": "^9.4.1",
    "@mantine/form": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mantine/modals": "^9.4.1",
    "@postfmly/logger": "^1.0.22",
    "big.js": "^7.0.1",
    "dayjs": "^1.11.21",
    "http-methods-constants": "^1.1.0",
    "jose": "^6.2.3",
    "ms": "^2.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "semver": "^7.8.5",
    "swr": "^2.4.2",
    "title-case": "^4.3.2",
    "valibot": "^1.4.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@happy-dom/global-registrator": "^20.10.6",
    "@postfmly/config": "^1.4.32",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/big.js": "^7.0.0",
    "@types/ms": "^2.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "expect-type": "^1.4.0",
    "fdir-size": "^1.0.3",
    "html-validate": "^11.5.5",
    "husky": "^9.1.7",
    "lcov-total": "^2.1.1",
    "lint-staged": "^17.0.8",
    "pretty-bytes": "^7.1.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-jsx-remove-attributes": "^3.1.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "vite-plugin-minify": "^3.0.0",
    "vite-plugin-package-version": "^1.1.0",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "~1.3.14"
  },
  "engineStrict": true,
  "patchedDependencies": {
    "@jarrodek/pluralize@1.0.2": "patches/@jarrodek%2Fpluralize@1.0.2.patch"
  }
}
